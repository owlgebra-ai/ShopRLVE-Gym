# EcomRLVE-GYM Space Configuration
# Copy to .env and fill in values

# HuggingFace API token (required for LLM user simulator)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# LLM model for user simulator (via HF Inference API)
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Path to pre-built FAISS HNSW index directory (contains index.faiss + ids.txt)
FAISS_INDEX_DIR=../data/faiss-index

# Path to product catalog (HF dataset or local directory)
CATALOG_PATH=../data/amazebay-2M

# Maximum products to load into memory for the catalog state
CATALOG_MAX_ITEMS=5000

# Sentence transformer model for embeddings
EMBEDDING_MODEL=thenlper/gte-small

# Compute device for embeddings (cpu / cuda / cuda:0)
EMBEDDING_DEVICE=cpu
